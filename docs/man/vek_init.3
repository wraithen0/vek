.\" vek_init(3) - Initialize VEK dispatch table
.\" Auto-generated from vek.h

.TH VEK_INIT 3 "2026" "vek 0.7.0" "Library Functions Manual"

.SH NAME
vek_init \- initialize VEK CPU dispatch table

.SH SYNOPSIS
.B #include <vek.h>
.PP
.B int vek_init(void);

.SH DESCRIPTION
.B vek_init()
initializes the internal CPU dispatch table by detecting the highest available
SIMD instruction set on the current processor. This function is thread-safe
and idempotent \- multiple calls have no additional effect.

The dispatch table selects the optimal backend at runtime:
.TP
.B scalar
Baseline implementation (always available)
.TP
.B sse2
Intel SSE2 (128-bit) \- available on all x86_64
.TP
.B avx2
Intel AVX2 + FMA (256-bit) \- Haswell and later
.TP
.B avx512
Intel AVX-512F + VNNI + VPOPCNTDQ (512-bit) \- Skylake-X and later
.TP
.B neon
ARM NEON (128-bit) \- ARM64 platforms

.SH RETURN VALUE
Returns 0 on success, -1 on failure.

.SH THREAD SAFETY
This function uses pthread_once internally and is safe to call from
multiple threads simultaneously.

.SH EXAMPLE
.PP
.B #include <vek.h>
.PP
.B int main() {
.PP
.B     vek_init();  \fR// Optional: called automatically on first API use
.PP
.B     const char *backend = vek_backend_name();
.PP
.B     printf("Using backend: %s\\n", backend);
.PP
.B     return 0;
.PP
.B }

